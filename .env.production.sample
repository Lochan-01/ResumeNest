# ================================
# ResumeNest - Production Environment
# CRITICAL: Never commit this file to Git
# ================================

# ========== Application Mode ==========
NODE_ENV=production
BUILD_TARGET=production

# ========== MongoDB Configuration ==========
# IMPORTANT: Change these credentials in production!
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_MIN_32_CHARS
MONGO_DATABASE=resume-builder

# ========== Backend Configuration ==========
JWT_SECRET=CHANGE_THIS_SUPER_SECRET_KEY_MIN_32_CHARS_RANDOM

# OpenAI API Key (required for AI features)
OPENAI_API_KEY=sk-your-openai-api-key-here

# ========== Frontend Configuration ==========
# Use /api for same-domain deployment or full URL for separate domains
VITE_API_URL=/api

# ========== Optional: External MongoDB (MongoDB Atlas) ==========
# Uncomment and use this if you're using MongoDB Atlas instead of local MongoDB
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/resume-builder?retryWrites=true&w=majority

# ========== Optional: Monitoring & Logging ==========
# SENTRY_DSN=
# LOG_LEVEL=info
