# Environment Variables

# Backend Configuration
PORT=3000
NODE_ENV=development
# Local MongoDB (for development)
# MONGODB_URI=mongodb://localhost:27017/resume-builder

# MongoDB Atlas (recommended for production)
# Get your connection string from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/resume-builder?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/resume-builder?retryWrites=true&w=majority

# JWT Secret (change this to a secure random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# OpenAI API Key (for AI bullet rewriter feature)
OPENAI_API_KEY=your-openai-api-key-here

# Frontend API URL
VITE_API_URL=http://localhost:3000/api
